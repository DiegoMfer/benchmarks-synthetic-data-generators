    sh:targetClass ub:Lecturer .

:Ontology a sh:NodeShape ;
    sh:property [ a sh:PropertyShape ;
            sh:maxCount 1 ;
            sh:minCount 0 ;
            sh:nodeKind sh:IRI ;
            sh:path owl:imports ],
        [ a sh:PropertyShape ;
            sh:in ( owl:Ontology ) ;
            sh:maxCount 1 ;
            sh:minCount 0 ;
            sh:path rdf:type ] ;
    sh:targetClass owl:Ontology .

:Publication a sh:NodeShape ;
    sh:property [ a sh:PropertyShape ;
            sh:minCount 0 ;
            sh:nodeKind sh:IRI ;
            sh:path ub:publicationAuthor ],
        [ a sh:PropertyShape ;
            sh:in ( ub:Publication ) ;
            sh:minCount 1 ;
            sh:maxCount 1 ;
            sh:minCount 0 ;
            sh:path rdf:type ],
        [ a sh:PropertyShape ;
            sh:dataType xsd:string ;
            sh:maxCount 1 ;
            sh:minCount 0 ;
            sh:path ub:name ] ;
    sh:targetClass ub:Publication .

