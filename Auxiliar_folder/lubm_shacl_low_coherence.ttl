@prefix : <http://weso.es/shapes/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix ub: <http://www.lehigh.edu/~yug2/Research/SemanticWeb/LUBM/univ-bench.owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

:AssistantProfessor a sh:NodeShape ;
    sh:property [ a sh:PropertyShape ;
            sh:minCount 0 ;
            sh:node :GraduateCourse ;
            sh:path ub:teacherOf ],
        [ a sh:PropertyShape ;
            sh:maxCount 1 ;
            sh:minCount 0 ;
            sh:node :University ;
            sh:path ub:mastersDegreeFrom ],
        [ a sh:PropertyShape ;
            sh:maxCount 1 ;
            sh:minCount 0 ;
            sh:node :University ;
            sh:path ub:doctoralDegreeFrom ],
        [ a sh:PropertyShape ;
            sh:dataType xsd:string ;
            sh:maxCount 1 ;
            sh:minCount 0 ;
            sh:path ub:researchInterest ],
        [ a sh:PropertyShape ;
            sh:maxCount 1 ;
            sh:minCount 0 ;
            sh:node :Department ;
            sh:path ub:worksFor ],
        [ a sh:PropertyShape ;
            sh:in ( ub:AssistantProfessor ) ;
            sh:minCount 1 ;
            sh:maxCount 1 ;
            sh:minCount 0 ;
            sh:path rdf:type ],
        [ a sh:PropertyShape ;
            sh:dataType xsd:string ;
            sh:maxCount 1 ;
            sh:minCount 0 ;
            sh:path ub:telephone ],
        [ a sh:PropertyShape ;
            sh:dataType xsd:string ;
            sh:maxCount 1 ;
            sh:minCount 0 ;
            sh:path ub:name ],
        [ a sh:PropertyShape ;
            sh:maxCount 1 ;
            sh:minCount 0 ;
            sh:node :University ;
            sh:path ub:undergraduateDegreeFrom ],
        [ a sh:PropertyShape ;
            sh:dataType xsd:string ;
            sh:maxCount 1 ;
            sh:minCount 0 ;
            sh:path ub:emailAddress ] ;
    sh:targetClass ub:AssistantProfessor .

:AssociateProfessor a sh:NodeShape ;
    sh:property [ a sh:PropertyShape ;
            sh:maxCount 1 ;
            sh:minCount 0 ;
            sh:node :University ;
            sh:path ub:mastersDegreeFrom ],
        [ a sh:PropertyShape ;
            sh:maxCount 1 ;
            sh:minCount 0 ;
            sh:node :Department ;
            sh:path ub:worksFor ],
        [ a sh:PropertyShape ;
            sh:maxCount 1 ;
            sh:minCount 0 ;
            sh:node :University ;
            sh:path ub:doctoralDegreeFrom ],
        [ a sh:PropertyShape ;
            sh:dataType xsd:string ;
            sh:maxCount 1 ;
            sh:minCount 0 ;
            sh:path ub:name ],
        [ a sh:PropertyShape ;
            sh:minCount 0 ;
            sh:node :Course ;
            sh:path ub:teacherOf ],
        [ a sh:PropertyShape ;
            sh:dataType xsd:string ;
            sh:maxCount 1 ;
            sh:minCount 0 ;
            sh:path ub:emailAddress ],
        [ a sh:PropertyShape ;
            sh:dataType xsd:string ;
            sh:maxCount 1 ;
            sh:minCount 0 ;
            sh:path ub:researchInterest ],
        [ a sh:PropertyShape ;
            sh:dataType xsd:string ;
            sh:maxCount 1 ;
            sh:minCount 0 ;
            sh:path ub:telephone ],
        [ a sh:PropertyShape ;
            sh:in ( ub:AssociateProfessor ) ;
            sh:minCount 1 ;
            sh:maxCount 1 ;
            sh:minCount 0 ;
            sh:path rdf:type ],
        [ a sh:PropertyShape ;
            sh:maxCount 1 ;
            sh:minCount 0 ;
            sh:node :University ;
            sh:path ub:undergraduateDegreeFrom ] ;
    sh:targetClass ub:AssociateProfessor .

:FullProfessor a sh:NodeShape ;
    sh:property [ a sh:PropertyShape ;
            sh:minCount 0 ;
            sh:node :Course ;
            sh:path ub:teacherOf ],
        [ a sh:PropertyShape ;
            sh:in ( ub:FullProfessor ) ;
            sh:minCount 1 ;
            sh:maxCount 1 ;
            sh:minCount 0 ;
            sh:path rdf:type ],
        [ a sh:PropertyShape ;
            sh:dataType xsd:string ;
            sh:maxCount 1 ;
            sh:minCount 0 ;
            sh:path ub:researchInterest ],
        [ a sh:PropertyShape ;
            sh:maxCount 1 ;
            sh:minCount 0 ;
            sh:node :University ;
            sh:path ub:doctoralDegreeFrom ],
        [ a sh:PropertyShape ;
            sh:dataType xsd:string ;
            sh:maxCount 1 ;
            sh:minCount 0 ;
            sh:path ub:telephone ],
        [ a sh:PropertyShape ;
            sh:maxCount 1 ;
            sh:minCount 0 ;
            sh:node :University ;
            sh:path ub:mastersDegreeFrom ],
        [ a sh:PropertyShape ;
            sh:dataType xsd:string ;
            sh:maxCount 1 ;
            sh:minCount 0 ;
            sh:path ub:emailAddress ],
        [ a sh:PropertyShape ;
            sh:maxCount 1 ;
            sh:minCount 0 ;
            sh:node :University ;
            sh:path ub:undergraduateDegreeFrom ],
        [ a sh:PropertyShape ;
            sh:dataType xsd:string ;
            sh:maxCount 1 ;
            sh:minCount 0 ;
            sh:path ub:name ],
        [ a sh:PropertyShape ;
            sh:maxCount 1 ;
            sh:minCount 0 ;
            sh:node :Department ;
            sh:path ub:worksFor ] ;
    sh:targetClass ub:FullProfessor .

:GraduateStudent a sh:NodeShape ;
    sh:property [ a sh:PropertyShape ;
            sh:maxCount 1 ;
            sh:minCount 0 ;
            sh:node :Department ;
            sh:path ub:memberOf ],
        [ a sh:PropertyShape ;
            sh:minCount 0 ;
            sh:node :GraduateCourse ;
            sh:path ub:takesCourse ],
        [ a sh:PropertyShape ;
            sh:dataType xsd:string ;
            sh:maxCount 1 ;
            sh:minCount 0 ;
            sh:path ub:telephone ],
        [ a sh:PropertyShape ;
            sh:dataType xsd:string ;
            sh:maxCount 1 ;
            sh:minCount 0 ;
            sh:path ub:emailAddress ],
        [ a sh:PropertyShape ;
            sh:in ( ub:GraduateStudent ) ;
            sh:minCount 1 ;
            sh:maxCount 1 ;
            sh:minCount 0 ;
            sh:path rdf:type ],
        [ a sh:PropertyShape ;
            sh:dataType xsd:string ;
            sh:maxCount 1 ;
            sh:minCount 0 ;
            sh:path ub:name ],
        [ a sh:PropertyShape ;
            sh:maxCount 1 ;
            sh:minCount 0 ;
            sh:node :University ;
            sh:path ub:undergraduateDegreeFrom ],
        [ a sh:PropertyShape ;
            sh:maxCount 1 ;
            sh:minCount 0 ;
            sh:nodeKind sh:IRI ;
            sh:path ub:advisor ] ;
    sh:targetClass ub:GraduateStudent .

:Lecturer a sh:NodeShape ;
    sh:property [ a sh:PropertyShape ;
            sh:in ( ub:Lecturer ) ;
            sh:minCount 1 ;
