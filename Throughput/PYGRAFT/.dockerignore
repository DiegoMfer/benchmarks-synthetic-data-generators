# PyGraft Docker ignore file
# Excludes files from Docker build context

# Output and generated data
output/
*.rdf
*.owl
*.ttl
*.nt
*.nq
*.json
*.yml
!docker-compose.yml

# Python artifacts
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
dist/
build/
*.egg

# Virtual environments
venv/
env/
ENV/
.venv

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Documentation
README.md
DOCKER_SETUP.md
*.md

# Scripts
*.sh

# Git
.git/
.gitignore
